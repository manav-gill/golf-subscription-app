{
  "info": {
    "name": "Golf Charity Subscription Platform API",
    "description": "Postman collection for Golf Charity Subscription Platform backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "authToken", "value": "", "type": "string" },
    { "key": "drawId", "value": "11111111-1111-1111-1111-111111111111", "type": "string" },
    { "key": "winnerId", "value": "11111111-1111-1111-1111-111111111111", "type": "string" },
    { "key": "charityId", "value": "11111111-1111-1111-1111-111111111111", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/signup", "host": ["{{baseUrl}}"], "path": ["api", "auth", "signup"] }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/users/me", "host": ["{{baseUrl}}"], "path": ["api", "users", "me"] }
          }
        },
        {
          "name": "Update Me",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"new-email@example.com\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/users/me", "host": ["{{baseUrl}}"], "path": ["api", "users", "me"] }
          }
        },
        {
          "name": "Activate Subscription",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/users/subscribe", "host": ["{{baseUrl}}"], "path": ["api", "users", "subscribe"] }
          }
        }
      ]
    },
    {
      "name": "Scores",
      "item": [
        {
          "name": "Add Score",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"score\": 15,\n  \"date\": \"2026-03-26\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/scores", "host": ["{{baseUrl}}"], "path": ["api", "scores"] }
          }
        },
        {
          "name": "Get Scores",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/scores", "host": ["{{baseUrl}}"], "path": ["api", "scores"] }
          }
        }
      ]
    },
    {
      "name": "Draw",
      "item": [
        {
          "name": "Run Draw (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/draw/run", "host": ["{{baseUrl}}"], "path": ["api", "draw", "run"] }
          }
        },
        {
          "name": "Get Current Draw",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/draw/current", "host": ["{{baseUrl}}"], "path": ["api", "draw", "current"] }
          }
        }
      ]
    },
    {
      "name": "Winners",
      "item": [
        {
          "name": "Get My Winnings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/winners/me", "host": ["{{baseUrl}}"], "path": ["api", "winners", "me"] }
          }
        },
        {
          "name": "Get Winners By Draw (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/winners/draw/{{drawId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "winners", "draw", "{{drawId}}"]
            }
          }
        },
        {
          "name": "Verify Winner (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"approved\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/winners/{{winnerId}}/verify",
              "host": ["{{baseUrl}}"],
              "path": ["api", "winners", "{{winnerId}}", "verify"]
            }
          }
        },
        {
          "name": "Distribute Prizes (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/winners/distribute/{{drawId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "winners", "distribute", "{{drawId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Charities",
      "item": [
        {
          "name": "Get Charities",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/charities", "host": ["{{baseUrl}}"], "path": ["api", "charities"] }
          }
        },
        {
          "name": "Get Charity By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/charities/{{charityId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "charities", "{{charityId}}"]
            }
          }
        },
        {
          "name": "Select Charity",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"charityId\": \"{{charityId}}\",\n  \"contributionPercentage\": 20\n}" },
            "url": { "raw": "{{baseUrl}}/api/charities/select", "host": ["{{baseUrl}}"], "path": ["api", "charities", "select"] }
          }
        },
        {
          "name": "Create Charity (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Green Charity\",\n  \"description\": \"Supports junior golfers\",\n  \"image_url\": \"https://example.com/charity.png\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/charities", "host": ["{{baseUrl}}"], "path": ["api", "charities"] }
          }
        },
        {
          "name": "Update Charity (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Green Charity Updated\",\n  \"description\": \"Updated description\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/charities/{{charityId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "charities", "{{charityId}}"]
            }
          }
        },
        {
          "name": "Delete Charity (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/charities/{{charityId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "charities", "{{charityId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    }
  ]
}
